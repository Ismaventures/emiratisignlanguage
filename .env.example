# Database
DATABASE_URL=postgresql://emirsign:emirsign_password@localhost:5432/emirsign
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Object Storage (MinIO for local, R2 for production)
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=emirsign
STORAGE_USE_SSL=false
STORAGE_REGION=auto

# AI Service URLs
VISION_SERVICE_URL=http://localhost:8001
NLP_SERVICE_URL=http://localhost:8002
SPEECH_SERVICE_URL=http://localhost:8003

# Whisper
WHISPER_MODEL_SIZE=base

# Piper TTS
PIPER_VOICE_PATH=./voices/ar_SA-Ahmed-medium.onnx

# App URLs
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_APP_NAME=EmirSign AI

# Frontend
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-secure-random-string

# Email (for verification, password reset)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@emirsign.ai

# Sentry (optional)
SENTRY_DSN=

# Analytics
ANALYTICS_ENABLED=true
